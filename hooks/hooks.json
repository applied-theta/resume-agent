{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-output.sh \"$CLAUDE_FILE_PATH\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'source ${CLAUDE_PLUGIN_ROOT}/.env-config 2>/dev/null && echo \"Session complete. Results saved to ${WORKSPACE_ROOT:-workspace/}\" || echo \"Session complete.\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/setup-deps.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
