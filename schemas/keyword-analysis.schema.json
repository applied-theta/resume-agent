{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["match_rate", "jd_requirements"],
  "properties": {
    "match_rate": { "type": "number", "minimum": 0, "maximum": 100 },
    "jd_requirements": {
      "type": "object",
      "properties": {
        "required_hard": { "type": "array", "items": { "type": "string" } },
        "preferred_hard": { "type": "array", "items": { "type": "string" } },
        "required_soft": { "type": "array", "items": { "type": "string" } },
        "experience_level": { "type": "string" },
        "industry_terms": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "exact_matches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": { "type": "string" },
          "locations": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "semantic_matches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "resume_term": { "type": "string" },
          "jd_term": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "critical_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": { "type": "string" },
          "priority": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "optimization_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "priority": { "type": "integer" },
          "action": { "type": "string" },
          "impact": { "type": "string" },
          "placement": { "type": "string" }
        }
      }
    }
  }
}
